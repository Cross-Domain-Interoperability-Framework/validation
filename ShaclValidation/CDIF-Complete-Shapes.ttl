cdifd:CDIFArchiveDistributionShape a sh:NodeShape ;
    sh:property [ sh:message "A dataset declaring CDIF archive distribution conformance should have at least one schema:distribution." ;
            sh:minCount 1 ;
            sh:path schema1:distribution ;
            sh:severity sh:Warning ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """
       PREFIX schema: <http://schema.org/>
            SELECT ?this
