                        sh:minCount 1 ;
                        sh:path schema1:url ;
                        sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ;
    sh:targetObjectsOf prov:wasDerivedFrom .

cdifd:fundingShape a sh:NodeShape ;
    sh:message "Funding for creation or maintenance of the resource can be acknowledged using schema:MonetaryGrant with at least one of: a funder, an identifier, a name, or a description." ;
    sh:or ( [ sh:property [ sh:minCount 1 ;
                        sh:or ( [ sh:nodeKind sh:IRI ] [ sh:class schema1:Person ] [ sh:class schema1:Organization ] ) ;
                        sh:path schema1:funder ] ] [ sh:property [ sh:message "a monetary Grant should have an identifier that is a resolvable URI" ;
                        sh:minCount 1 ;
                        sh:or ( [ sh:nodeKind sh:IRIOrLiteral ] [ sh:and ( [ sh:class schema1:PropertyValue ] [ sh:or ( [ sh:property [ sh:datatype xsd:string ;
                                                                    sh:message "a value for the identifier should be provided; can provide either full URI or identifier token part of URI if a url is provided." ;
                                                                    sh:minCount 1 ;
                                                                    sh:path schema1:value ] ] [ sh:property [ sh:datatype xsd:string ;
                                                                    sh:message "value must be a resolvable URL, but we aren't testing to see if the URL resolves..... Can't get xsd:anyURI to work with JSON Schema validation..." ;
                                                                    sh:minCount 1 ;
                                                                    sh:path schema1:url ;
                                                                    sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ] ) ] ) ;
                        sh:path schema1:identifier ] ] [ sh:property cdifd:grantNameProperty ] [ sh:property [ sh:datatype xsd:string ;
                        sh:minCount 1 ;
                        sh:path schema1:description ] ] ) ;
    sh:targetClass schema1:MonetaryGrant .

cdifd:generatedByNode a sh:NodeShape ;
    sh:property [ sh:message "The generatedBy Activity must specify at least one resource that was used" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:nodeKind sh:BlankNode ] [ sh:datatype xsd:string ;
                        sh:minLength 3 ] ) ;
            sh:path prov:used ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """
      PREFIX schema: <http://schema.org/>
      PREFIX prov: <http://www.w3.org/ns/prov#>
      SELECT DISTINCT ?this
        WHERE {
        ?this a prov:Activity .
        {
          ?this schema:name "example generated by" .
          FILTER NOT EXISTS { ?s ?p ?this . }
        }
        Union
        {
          ?s prov:wasGeneratedBy ?this .
        }
      }""" ] .

cdifd:instrumentNode a sh:NodeShape ;
    sh:property [ sh:message "An instrument should have a domain-specific type URI (schema:additionalType)." ;
            sh:path schema1:additionalType ;
            sh:severity sh:Info ],
        [ sh:message "An instrument should have a landing page URL (schema:url)." ;
            sh:path schema1:url ;
            sh:severity sh:Info ],
        [ sh:message "An instrument should have a commissioned date (schema:validFrom)." ;
            sh:path schema1:validFrom ;
            sh:severity sh:Info ],
        [ sh:datatype xsd:string ;
            sh:message "An instrument must have a name with at least 3 characters." ;
            sh:minCount 1 ;
            sh:minLength 3 ;
            sh:path schema1:name ;
            sh:severity sh:Violation ],
        [ sh:message "An instrument should have a category classification from a controlled vocabulary (schema:category)." ;
            sh:minCount 1 ;
            sh:path schema1:category ;
            sh:severity sh:Warning ],
        [ sh:message "An instrument should have an identifier (schema:identifier)." ;
            sh:path schema1:identifier ;
            sh:severity sh:Info ],
        [ sh:datatype xsd:string ;
            sh:message "An instrument should have a text description." ;
            sh:path schema1:description ;
            sh:severity sh:Info ],
        [ sh:message "An instrument should identify its manufacturer (schema:manufacturer)." ;
            sh:path schema1:manufacturer ;
            sh:severity sh:Info ],
        [ sh:message "An instrument should specify its product model (schema:model)." ;
            sh:path schema1:model ;
            sh:severity sh:Info ],
        [ sh:message "An instrument should identify its owner (schema:owner)." ;
            sh:path schema1:owner ;
            sh:severity sh:Info ],
        [ sh:message "An instrument should identify contributors with roles (e.g. operator, custodian, PI)." ;
            sh:path schema1:contributor ;
            sh:severity sh:Info ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """
      PREFIX schema: <http://schema.org/>
      SELECT DISTINCT ?this
        WHERE {
          ?s schema:instrument ?this .
          FILTER (isIRI(?this) || isBlank(?this))
          }""" ] .

cdifd:longDataShape a sh:NodeShape ;
    sh:property [ sh:message "A LongStructureDataSet should have physical mappings (cdi:hasPhysicalMapping) linking variables to columns." ;
            sh:minCount 1 ;
            sh:path cdi:hasPhysicalMapping ;
            sh:severity sh:Warning ],
        [ sh:message "A LongStructureDataSet must format exactly one InstanceVariable with cdi:role 'DescriptorComponent' (the column identifying which variable each row measures)." ;
            sh:path ( cdi:hasPhysicalMapping cdi:formats_InstanceVariable cdi:role ) ;
            sh:qualifiedMaxCount 1 ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape [ sh:hasValue "DescriptorComponent" ] ;
            sh:severity sh:Violation ],
        [ sh:message "A LongStructureDataSet must format at least one InstanceVariable with cdi:role 'ReferenceValueComponent' (the column holding the actual measured values)." ;
            sh:path ( cdi:hasPhysicalMapping cdi:formats_InstanceVariable cdi:role ) ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape [ sh:hasValue "ReferenceValueComponent" ] ;
            sh:severity sh:Violation ] ;
    sh:targetClass cdi:LongStructureDataSet .

cdifd:maintainerOrProviderContactPointShape a sh:NodeShape ;
    sh:property [ sh:message "A maintainer or provider Person should have a contactPoint for users to reach" ;
            sh:minCount 1 ;
            sh:or ( [ sh:class schema1:ContactPoint ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path schema1:contactPoint ;
            sh:severity sh:Warning ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """
            PREFIX schema: <http://schema.org/>
            SELECT ?this WHERE {
                { ?record schema:maintainer ?this . }
                UNION
                { ?record schema:provider ?this . }
                ?this a schema:Person .
            }
        """ ] .

cdifd:name2Property a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "a name for the variable must be provided, and have a length of at least 5 characters." ;
    sh:minCount 1 ;
    sh:minLength 5 ;
    sh:path schema1:name .

cdifd:physicalMappingShape a sh:NodeShape ;
    sh:message "Physical mapping nodes should link to their corresponding variable definition." ;
    sh:property [ sh:message "A physical mapping should reference the variable it formats (cdi:formats_InstanceVariable)." ;
            sh:minCount 1 ;
            sh:path cdi:formats_InstanceVariable ;
            sh:severity sh:Warning ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """
            PREFIX cdi: <http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/>
            SELECT ?this
            WHERE {
                ?parent cdi:hasPhysicalMapping ?this .
            }
        """ ] .

cdifd:propertyNode a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "provide a meaningful name for the measured property" ;
            sh:minCount 1 ;
            sh:path schema1:name ;
            sh:severity sh:Warning ],
        [ sh:datatype xsd:string ;
            sh:message "if possible, specify the property associated with the variable with an IRI" ;
            sh:minCount 1 ;
            sh:path schema1:identifier ;
            sh:severity sh:Info ] ;
    sh:targetClass schema1:Property .

cdifd:provActivityHowToShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "A HowTo methodology must have a schema:name" ;
            sh:minCount 1 ;
            sh:path schema1:name ;
            sh:severity sh:Violation ],
        [ sh:class schema1:HowToStep ;
            sh:message "HowTo steps should be of type schema:HowToStep" ;
            sh:path schema1:step ;
            sh:severity sh:Warning ] ;
    sh:targetClass schema1:HowTo .

cdifd:provActivityHowToStepShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "A HowToStep must have a schema:name" ;
            sh:minCount 1 ;
            sh:path schema1:name ;
            sh:severity sh:Violation ],
        [ sh:datatype xsd:integer ;
            sh:message "A HowToStep should specify a schema:position (integer)" ;
            sh:path schema1:position ;
            sh:severity sh:Warning ] ;
    sh:targetClass schema1:HowToStep .

cdifd:provActivityShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "A provActivity should have a schema:description" ;
            sh:path schema1:description ;
            sh:severity sh:Warning ],
        [ sh:message "A provActivity should identify a responsible agent via prov:wasAssociatedWith (schema:Person, schema:Organization, or IRI reference)" ;
            sh:or ( [ sh:class schema1:Person ] [ sh:class schema1:Organization ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasAssociatedWith ;
            sh:severity sh:Warning ],
        [ sh:datatype xsd:string ;
            sh:message "A provActivity should specify a prov:startedAtTime (ISO8601 date-time)" ;
            sh:path prov:startedAtTime ;
            sh:severity sh:Warning ],
        [ sh:datatype xsd:string ;
            sh:message "A provActivity should specify a prov:endedAtTime (ISO8601 date-time)" ;
            sh:path prov:endedAtTime ;
            sh:severity sh:Warning ],
        [ sh:message "A provActivity must specify at least one resource that was used (prov:used)" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:nodeKind sh:BlankNode ] [ sh:datatype xsd:string ;
                        sh:minLength 3 ] ) ;
            sh:path prov:used ;
            sh:severity sh:Violation ],
        [ sh:message "prov:generated identifies entities produced by this activity" ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:nodeKind sh:BlankNode ] [ sh:datatype xsd:string ] ) ;
            sh:path prov:generated ;
            sh:severity sh:Info ],
        [ sh:message "prov:wasInformedBy links to prior activities in a provenance chain" ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:nodeKind sh:BlankNode ] [ sh:datatype xsd:string ] ) ;
            sh:path prov:wasInformedBy ;
            sh:severity sh:Info ],
        [ sh:message "prov:atLocation should be a schema:Place, IRI, or descriptive string" ;
            sh:or ( [ sh:class schema1:Place ] [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] ) ;
            sh:path prov:atLocation ;
            sh:severity sh:Info ],
        [ sh:message "Instruments should be a DefinedTerm, CreativeWork, IRI, or descriptive string" ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] [ sh:class schema1:DefinedTerm ] [ sh:class schema1:CreativeWork ] ) ;
            sh:path schema1:instrument ;
            sh:severity sh:Info ],
        [ sh:in ( "schema:CompletedActionStatus" "schema:ActiveActionStatus" "schema:PotentialActionStatus" "schema:FailedActionStatus" ) ;
            sh:message "schema:actionStatus should be one of: schema:CompletedActionStatus, schema:ActiveActionStatus, schema:PotentialActionStatus, schema:FailedActionStatus" ;
            sh:path schema1:actionStatus ;
            sh:severity sh:Info ],
        [ sh:message "schema:actionProcess should be a HowTo, IRI reference, or descriptive string" ;
            sh:or ( [ sh:class schema1:HowTo ] [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] ) ;
            sh:path schema1:actionProcess ;
            sh:severity sh:Info ],
        [ sh:datatype xsd:string ;
            sh:message "A provActivity should have a schema:name of at least 5 characters" ;
            sh:minCount 1 ;
            sh:minLength 5 ;
            sh:path schema1:name ;
            sh:severity sh:Warning ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """
	  PREFIX schema: <http://schema.org/>
	  PREFIX prov: <http://www.w3.org/ns/prov#>
	  SELECT DISTINCT ?this
	    WHERE {
	    ?this a prov:Activity .
	    {
	      FILTER NOT EXISTS { ?s ?p ?this . }
	    }
	    UNION
	    {
	      ?s prov:wasGeneratedBy ?this .
	    }
	  }""" ] .

cdifd:qualityMeasurementNode a sh:NodeShape ;
    sh:property [ sh:message "a quality measurement must specify the Measurement test with a name, IRI ref, or Defined Term" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ;
                        sh:minLength 3 ] [ sh:class schema1:DefinedTerm ] ) ;
            sh:path dqv:isMeasurementOf ],
        [ sh:message "a dataquality measurement must report a result value" ;
            sh:minCount 1 ;
            sh:or ( [ sh:datatype xsd:string ] [ sh:class schema1:DefinedTerm ] ) ;
            sh:path dqv:value ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """
      PREFIX schema: <http://schema.org/>
      PREFIX dqv: <http://www.w3.org/ns/dqv#>
      SELECT DISTINCT ?this
        WHERE {
        ?this a dqv:QualityMeasurement .
        {
          ?this schema:name "example additional property" .
          FILTER NOT EXISTS { ?s ?p ?this . }
        }
        Union
        {
          ?s schema:additionalProperty ?this .
        }
      }""" ] ;
    sh:targetClass dqv:QualityMeasurement .

cdifd:spatialExtentProperty a sh:NodeShape ;
    sh:message "Recommended: provide a spatial coverage description if applicable using schema:Place, either a place name,  point location(s) (GeoCoordinates), or GeoShape (bounding box, line profile location, or polygon)." ;
    sh:or ( [ sh:property [ sh:message "Spatial location MUST be specified either with GeoCoordinates lat/long pairs or with GeoShape Line or Box." ;
                        sh:minCount 1 ;
                        sh:or ( [ sh:node cdifd:geoCoordinatesNode ] [ sh:node cdifd:geoShapeNode ] ) ;
                        sh:path schema1:geo ] ] [ sh:property [ sh:minCount 1 ;
                        sh:or ( [ sh:datatype xsd:string ] [ sh:node cdifd:CDIFDefinedTermShape ] ) ;
                        sh:path schema1:name ] ] ) ;
    sh:targetClass schema1:Place .

cdifd:statisticalVariableNode a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "A StatisticalVariable must have a name (schema:name) with at least 3 characters." ;
            sh:minCount 1 ;
            sh:minLength 3 ;
            sh:path schema1:name ],
        [ sh:message "A StatisticalVariable must specify the property being measured (schema:measuredProperty)." ;
            sh:minCount 1 ;
            sh:path schema1:measuredProperty ],
        [ sh:message "A StatisticalVariable should specify a statType as a string, IRI, or DefinedTerm." ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] [ sh:class schema1:DefinedTerm ] ) ;
            sh:path schema1:statType ;
            sh:severity sh:Warning ] ;
    sh:targetClass schema1:StatisticalVariable .

cdifd:tabularDataShape a sh:NodeShape ;
    sh:message "A TabularTextDataSet must specify either cdi:isDelimited=true or cdi:isFixedWidth=true." ;
    sh:or ( [ sh:property [ sh:hasValue true ;
                        sh:path cdi:isDelimited ] ] [ sh:property [ sh:hasValue true ;
                        sh:path cdi:isFixedWidth ] ] ) ;
    sh:property [ sh:message "A TabularTextDataSet should have physical mappings (cdi:hasPhysicalMapping) linking variables to columns." ;
            sh:minCount 1 ;
            sh:path cdi:hasPhysicalMapping ;
            sh:severity sh:Warning ] ;
    sh:targetClass cdi:TabularTextDataSet .

cdifd:temporalExtentProperty a sh:PropertyShape ;
    sh:message "temporalCoverage problem; need an ISO 8601 dateTime, ISO 8601 time interval (two xsd:date separated by a '/' character),  or a time:ProperInterval. ISO time interval allows YYYY, YYYY-MM, or YYYY-DD-MM" ;
    sh:minCount 0 ;
    sh:or ( [ sh:class time:ProperInterval ] [ sh:class time:Instant ] [ sh:datatype xsd:string ;
                sh:or ( [ sh:pattern "^[1-2][0-9]{3}-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1])(T([0-1][0-9]|[2][0-3]):[0-5][0-9](:[0-5][0-9](Z|[+-][0-2][0-9]:[0-5][0-9])?)?)?)?$" ] [ sh:pattern "^(([1-2][0-9]{3}(-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1]))?)?)|(\\.\\.))\\/([1-2][0-9]{3}(-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1]))?)?)|(\\.\\.)$" ] ) ] ) ;
    sh:path schema1:temporalCoverage .

cdifd:timeInstantNode a sh:NodeShape ;
    sh:property [ sh:class time:TimePosition ;
            sh:message "a time instant must have a TimePosition object as a value" ;
            sh:path time:inTimePosition ] ;
    sh:targetClass time:Instant .

cdifd:timeIntervalNode a sh:NodeShape ;
    sh:property [ sh:class time:Instant ;
            sh:message "A time interval must have a beginning " ;
            sh:minCount 1 ;
            sh:path time:hasBeginning ],
        [ sh:class time:Instant ;
            sh:message "A time interval must have an end " ;
            sh:minCount 1 ;
            sh:path time:hasEnd ] ;
    sh:targetClass time:ProperInterval .

cdifd:timePositionNode a sh:NodeShape ;
    sh:property [ sh:message "include identifier for the temporal reference system as a string or @id with a URI value" ;
            sh:nodeKind sh:IRIOrLiteral ;
            sh:path time:hasTRS ],
        [ sh:message "time position MUST have a numeric value" ;
            sh:or ( [ sh:datatype xsd:integer ] [ sh:datatype xsd:double ] ) ;
            sh:path time:numericPosition ] ;
    sh:targetClass time:TimePosition .

cdifd:webAPINode a sh:NodeShape ;
    sh:property [ sh:message "A WebAPI node must specify a service type with a string, IRI, or DefinedTerm" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:class schema1:DefinedTerm ] [ sh:datatype xsd:string ;
                        sh:minLength 3 ] ) ;
            sh:path schema1:serviceType ],
        [ sh:message "A WebAPI must specify terms of service (schema:termsOfService) as a string, IRI, or CreativeWork." ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] [ sh:class schema1:CreativeWork ] ) ;
            sh:path schema1:termsOfService ],
        [ sh:message "at least one action must be provided for a webAPI distribution" ;
            sh:minCount 1 ;
            sh:or ( [ sh:class schema1:Action ] [ sh:class schema1:AssessAction ] [ sh:class schema1:ConsumeAction ] [ sh:class schema1:ControlAction ] [ sh:class schema1:CreateAction ] [ sh:class schema1:DeleteAction ] [ sh:class schema1:FindAction ] [ sh:class schema1:InteractAction ] [ sh:class schema1:MoveAction ] [ sh:class schema1:PlayAction ] [ sh:class schema1:SearchAction ] [ sh:class schema1:TransferAction ] [ sh:class schema1:UpdateAction ] ) ;
            sh:path schema1:potentialAction ],
        [ sh:message "a link or URL to a machine-actionable service distribution object should be provided if it exists" ;
            sh:minCount 1 ;
            sh:or ( [ sh:class schema1:CreativeWork ] [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] ) ;
            sh:path schema1:documentation ;
            sh:severity sh:Info ] ;
    sh:targetClass schema1:WebAPI .

<https://www.ogc.org/rules/template/#ConformsToInfo> a sh:NodeShape ;
    sh:property [ sh:message "Recommended: include dcterms:conformsTo to identify the standard or specification this distribution conforms to." ;
            sh:minCount 1 ;
            sh:path dcterms:conformsTo ;
            sh:severity sh:Info ] ;
    sh:targetClass schema1:DataDownload .

cdifd:CDIFDefinedTermShape a sh:NodeShape ;
    sh:message "A DefinedTerm must have a name (label), an identifier, OR a termCode. All three are recommended." ;
    sh:or ( [ sh:property [ sh:message "a defined term should have an identifier that is a resolvable URI" ;
                        sh:minCount 1 ;
                        sh:or ( [ sh:datatype xsd:string ] [ sh:and ( [ sh:class schema1:PropertyValue ] [ sh:or ( [ sh:property [ sh:datatype xsd:string ;
                                                                    sh:message "a value for the identifier should be provided; can provide either full URI or identifier token part of URI if a url is provided." ;
                                                                    sh:minCount 1 ;
                                                                    sh:path schema1:value ] ] [ sh:property [ sh:datatype xsd:string ;
                                                                    sh:message "value expected to be a resolvable http URI, but we aren't testing to see if the URL resolves..." ;
                                                                    sh:minCount 1 ;
                                                                    sh:path schema1:url ;
                                                                    sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ] ) ] ) ;
                        sh:path schema1:identifier ] ] [ sh:property cdifd:termLabelProperty ] [ sh:property [ sh:datatype xsd:string ;
                        sh:message "a termCode (short code or notation) for the term within its vocabulary" ;
                        sh:minCount 1 ;
                        sh:path schema1:termCode ] ] ) ;
    sh:property [ sh:message "inDefinedTermSet identifies the controlled vocabulary from which this term comes; should be a URI or string identifier" ;
            sh:minCount 0 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] ) ;
            sh:path schema1:inDefinedTermSet ;
            sh:severity sh:Info ],
        [ sh:datatype xsd:string ;
            sh:message "termCode is a short code or notation for the term within its vocabulary (analogous to skos:notation)" ;
            sh:minCount 0 ;
            sh:path schema1:termCode ;
            sh:severity sh:Info ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """
      PREFIX schema: <http://schema.org/>
      SELECT DISTINCT ?this
        WHERE {
        ?this a schema:DefinedTerm .
        {
          ?this schema:name "example defined term" .
          FILTER NOT EXISTS { ?s ?p ?this . }
        }
        Union
        {
         VALUES ?p {
            schema:linkRelationship
            schema:measurementTechnique
            schema:keywords
            schema:name
          }
         ?s ?p ?this .
        }
      }""" ] .

cdifd:additionalPropertyNameProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "a name for the additional property must be provided, and have a lenght of at least 5 characters." ;
    sh:minCount 1 ;
    sh:minLength 5 ;
    sh:path schema1:name .

cdifd:affiliationProperty a sh:PropertyShape ;
    sh:message "Optional: an affiliation must have object schema:Organization" ;
    sh:minCount 0 ;
    sh:or ( [ sh:class schema1:Organization ] [ sh:nodeKind sh:IRI ] ) ;
    sh:path schema1:affiliation ;
    sh:severity sh:Warning .

cdifd:citationProperty a sh:PropertyShape ;
    sh:description "https://cross-domain-interoperability-framework.github.io/cdifbook/metadata/schemaorgimplementation.html" ;
    sh:maxCount 0 ;
    sh:message "schema:citation is not recommended for use in CDIF because of semantic ambiguity. Use dcterms:bibliographicCitation for recommended citation, or schema:relatedLink for related resources." ;
    sh:path schema1:citation ;
    sh:severity sh:Info .

cdifd:contactPointProperty a sh:PropertyShape ;
    sh:message "A Person should have a contactPoint (schema:ContactPoint or mailto: IRI)" ;
    sh:minCount 1 ;
    sh:or ( [ sh:class schema1:ContactPoint ] [ sh:nodeKind sh:IRI ] ) ;
    sh:path schema1:contactPoint ;
    sh:severity sh:Info .

cdifd:contributorProperty a sh:PropertyShape ;
    sh:description "https://cross-domain-interoperability-framework.github.io/cdifbook/metadata/schemaorgimplementation.html" ;
    sh:message "Contributors should be a Role, Person, Organization, or IRI reference to one" ;
    sh:minCount 0 ;
    sh:or ( [ sh:class schema1:Role ] [ sh:class schema1:Person ] [ sh:class schema1:Organization ] [ sh:nodeKind sh:IRI ] ) ;
    sh:path schema1:contributor ;
    sh:severity sh:Info .

cdifd:dateModifiedProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "Date of most recent update to resource content is required, using ISO8601 format with at least a year and a month." ;
    sh:minCount 1 ;
    sh:path schema1:dateModified ;
    sh:pattern "^[1-2][0-9]{3}-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1])(T([0-1][0-9]|[2][0-3]):[0-5][0-9](:[0-5][0-9](Z|[+-][0-2][0-9]:[0-5][0-9])?)?)?)?$" .

cdifd:datePublishedProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "Please provide a publication or release date, using ISO8601 format with at least a year and a month." ;
    sh:minCount 1 ;
    sh:path schema1:datePublished ;
    sh:pattern "^[1-2][0-9]{3}-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1])(T([0-1][0-9]|[2][0-3]):[0-5][0-9](:[0-5][0-9](Z|[+-][0-2][0-9]:[0-5][0-9])?)?)?)?$" ;
    sh:severity sh:Info .

cdifd:distributionProperty a sh:PropertyShape ;
    sh:message "a schema:distribution must have either a DataDownload or WebAPI value" ;
    sh:minCount 0 ;
    sh:or ( [ sh:class schema1:DataDownload ] [ sh:class schema1:WebAPI ] ) ;
    sh:path schema1:distribution ;
    sh:severity sh:Info .

cdifd:geoCoordinatesNode a sh:NodeShape ;
    sh:message "GeoCoodinates must include latitude between -90 and 90, and longitude between -180 and 180." ;
    sh:property [ sh:maxValue 90.0 ;
            sh:minCount 1 ;
            sh:minValue -90.0 ;
            sh:or ( [ sh:datatype xsd:double ] [ sh:datatype xsd:integer ] ) ;
            sh:path schema1:latitude ],
        [ sh:maxValue 180.0 ;
            sh:minCount 1 ;
            sh:minValue -180.0 ;
            sh:or ( [ sh:datatype xsd:double ] [ sh:datatype xsd:integer ] ) ;
            sh:path schema1:longitude ] ;
    sh:targetClass schema1:GeoCoordinates .

cdifd:geoShapeNode a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "geoshape must include a line or box geometry as a string of latitude longitude pairs" ;
            sh:minCount 1 ;
            sh:path [ sh:alternativePath ( schema1:line schema1:box ) ] ] ;
    sh:targetClass schema1:GeoShape .

cdifd:getResourceProperty a sh:PropertyShape ;
    sh:message "Provide either a schema:url for a landing page or a schema:distribution (DataDownload or WebAPI) for direct access to the dataset" ;
    sh:minCount 1 ;
    sh:path [ sh:alternativePath ( schema1:url schema1:distribution ) ] ;
    sh:severity sh:Warning .

cdifd:grantNameProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "a title for the grant must be provided, and have a length of at least 5 characters." ;
    sh:minCount 1 ;
    sh:minLength 5 ;
    sh:path schema1:name .

cdifd:keywordsNoCommaTest a sh:PropertyShape ;
    sh:description "https://cross-domain-interoperability-framework.github.io/cdifbook/metadata/schemaorgimplementation.html" ;
    sh:message "If there are multiple keywords, they should be in an array; an individual keyword MUST not contain a comma character" ;
    sh:or ( [ sh:datatype xsd:string ;
                sh:pattern "^[^,]*$" ] [ sh:nodeKind sh:BlankNodeOrIRI ] ) ;
    sh:path schema1:keywords ;
    sh:severity sh:Warning .

cdifd:metadataIdentifierProperty a sh:PropertyShape ;
    sh:message "The URI for the metadata record should be the @id value for the 'subjectOf' element in the JSON instance document tree or '@id':{uri} in a separate graph node referencing the resource description node" ;
    sh:nodeKind sh:IRI ;
    sh:path schema1:subjectOf ;
    sh:severity sh:Warning .

cdifd:metadataProfileProperty a sh:PropertyShape ;
    sh:hasValue <https://w3id.org/cdif/core/1.0/> ;
    sh:message "provide identifiers for specifications used in this record to provide guidance for machine agents processing the metadata record" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path dcterms:conformsTo .

cdifd:metadataSubjectProperty a sh:PropertyShape ;
    sh:message "link to the target of the metadata metadata node using the about property" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path schema1:about .

cdifd:name3Property a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "a name for the variable must be provided, and have a length of at least 2 characters." ;
    sh:minCount 1 ;
    sh:minLength 2 ;
    sh:path schema1:name .

cdifd:otherIdentifierProperty a sh:PropertyShape ;
    sh:message "other identifiers for the described resource should be an IRI, literal string, or schema:PropertyValue" ;
    sh:or ( [ sh:nodeKind sh:IRIOrLiteral ] [ sh:class schema1:PropertyValue ] ) ;
    sh:path schema1:sameAs ;
    sh:severity sh:Info .

cdifd:policiesProperty a sh:PropertyShape ;
    sh:message "publication principles and policies must be provided as a schema:CreativeWork, with a schema:name and either a link (schema:url) or a description of the policy" ;
    sh:minCount 0 ;
    sh:or ( [ sh:nodeKind sh:IRI ] [ sh:class schema1:CreativeWork ;
                sh:property [ sh:datatype xsd:string ;
                        sh:message "provide a URL linking to a policy statement or a text description of the policy" ;
                        sh:minCount 1 ;
                        sh:path [ sh:alternativePath ( schema1:url schema1:description ) ] ],
                    [ sh:datatype xsd:string ;
                        sh:message "provide a meaningful label for this policy statement" ;
                        sh:minCount 1 ;
                        sh:path schema1:name ;
                        sh:severity sh:Info ] ] ) ;
    sh:path schema1:publishingPrinciples ;
    sh:severity sh:Info .

cdifd:providerProperty a sh:PropertyShape ;
    sh:message "if a provider agent is specified it must be either a schema:Person, schema:Organization, or a resolvable URI" ;
    sh:minCount 0 ;
    sh:or ( [ sh:nodeKind sh:IRI ] [ sh:class schema1:Person ] [ sh:class schema1:Organization ] ) ;
    sh:path schema1:provider ;
    sh:severity sh:Info .

cdifd:relatedResourceProperty a sh:PropertyShape ;
    sh:class schema1:LinkRole ;
    sh:message "links to related resource use schema:LinkRole, with a linkRelationship (string or IRI), and at least a target schema:url" ;
    sh:minCount 0 ;
    sh:path schema1:relatedLink ;
    sh:property [ sh:message "a link to a related resource must specify the relationship to that resource, either with a string label, IRI, or DefinedTerm" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] [ sh:class schema1:DefinedTerm ] ) ;
            sh:path schema1:linkRelationship ],
        [ sh:class schema1:EntryPoint ;
            sh:path schema1:target ;
            sh:property [ sh:datatype xsd:string ;
                    sh:path schema1:encodingType ],
                [ sh:datatype xsd:string ;
                    sh:path schema1:name ],
                [ sh:datatype xsd:string ;
                    sh:message "a URL must be provided for a link to a related resource" ;
                    sh:minCount 1 ;
                    sh:path schema1:url ] ] ;
    sh:severity sh:Info .

cdifd:resourceIdentifierProperty a sh:PropertyShape ;
    sh:message "An identifier for the documented resource must be provided" ;
    sh:minCount 1 ;
    sh:or ( [ sh:datatype xsd:string ] [ sh:class schema1:PropertyValue ;
                sh:or ( [ sh:property [ sh:datatype xsd:string ;
                                    sh:message "if possible, provide a resolvable URI that will provide a representation of the identified resource." ;
                                    sh:path schema1:url ] ] [ sh:property [ sh:datatype xsd:string ;
                                    sh:message "The identifer string; include applicable prefix (e.g. doi:, ark:, http:, isbn:)" ;
                                    sh:path schema1:value ] ] ) ;
                sh:property [ sh:datatype xsd:string ;
                        sh:message "If specifying an identifier via the PropertyValue, the scheme (authority, domain) within which the identifier is assigned and unique must be identifed, either by name or preferably using a URI. See https://registry.identifiers.org/registry" ;
                        sh:path schema1:propertyID ;
                        sh:severity sh:Warning ] ] ) ;
    sh:path schema1:identifier .

cdifd:resourceMetadataProfileProperty a sh:PropertyShape ;
    sh:message "provide identifiers for specifications and datatypes used in this record to provide guidance for machine agents processing the metadata record" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRIOrLiteral ;
    sh:path ( schema1:subjectOf dcterms:conformsTo ) ;
    sh:severity sh:Warning .

cdifd:responsiblePartyProperty a sh:PropertyShape ;
    sh:description "https://cross-domain-interoperability-framework.github.io/cdifbook/metadata/schemaorgimplementation.html" ;
    sh:message "Recommended: identify at least one responsible party as the source authority for the dataset. Options include creator, editor, or publisher." ;
    sh:minCount 1 ;
    sh:path [ sh:alternativePath ( schema1:creator schema1:editor schema1:publisher ) ] ;
    sh:severity sh:Info .

cdifd:rightsProperty a sh:PropertyShape ;
    sh:message "To meet the requirements for FAIR data, information about licenses or other security, usage, or access limitations must be described" ;
    sh:minCount 1 ;
    sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] [ sh:class schema1:CreativeWork ;
                sh:property [ sh:datatype xsd:string ;
                        sh:message "value must be a resolvable URL, but we aren't testing to see if the URL resolves..... Can't get xsd:anyURI to work with JSON Schema validation..." ;
                        sh:minCount 1 ;
                        sh:path schema1:url ;
                        sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ;
    sh:path [ sh:alternativePath ( schema1:license schema1:conditionsOfAccess ) ] .

cdifd:roleNameProperty a sh:PropertyShape ;
    sh:message "a Role must provide a roleName, ideally the value is a term from a controlled vocabulary or an IRI for a role concept. For terms from a vocabulary, recommend using schema:DefinedTerm" ;
    sh:minCount 1 ;
    sh:or ( [ sh:datatype xsd:string ] [ sh:class schema1:DefinedTerm ] ) ;
    sh:path schema1:roleName .

cdifd:termLabelProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "a label (schema:name) for the term must be provided, and must have at least 5 characters" ;
    sh:minCount 1 ;
    sh:minLength 5 ;
    sh:path schema1:name .

cdifd:nameProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "a name for the person must be provided, and have a lenght of at least 5 characters." ;
    sh:minCount 1 ;
    sh:minLength 5 ;
    sh:path schema1:name .

